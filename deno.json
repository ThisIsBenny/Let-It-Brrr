{
  "version": "2",
  "tasks": {
    "dev": "deno run --watch --allow-net=api.brrr.now --allow-read=config/ --allow-env=LOG_LEVEL,PORT,BRRR_SECRET,BRRR_WEBHOOK_URL,MAPPINGS_FILE src/main.ts",
    "start": "deno run --allow-net=api.brrr.now --allow-read=config/ --allow-env=LOG_LEVEL,PORT,BRRR_SECRET,BRRR_WEBHOOK_URL,MAPPINGS_FILE src/main.ts",
    "test": "deno test --allow-read --allow-net=api.brrr.now,127.0.0.1 --allow-env=LOG_LEVEL,PORT,BRRR_SECRET,BRRR_WEBHOOK_URL,MAPPINGS_FILE",
    "test:coverage": "deno test --coverage --allow-read --allow-net=api.brrr.now,127.0.0.1 --allow-env=LOG_LEVEL,PORT,BRRR_SECRET,BRRR_WEBHOOK_URL,MAPPINGS_FILE",
    "lint": "deno lint",
    "typecheck": "deno check src/main.ts"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.9",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/yaml": "jsr:@std/yaml@^1.0.12"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  },
  "exclude": ["node_modules/", "dist/", "coverage/"]
}